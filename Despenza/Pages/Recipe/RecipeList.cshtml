@page
@model Despenza.Pages.RecipeListModel

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Mine Opskrifter</h2>
        <a asp-page="/Recipe/CreateRecipe" class="btn btn-primary">Ny opskrift</a>
    </div>

    <div class="accordion" id="recipeAccordion">
        @if (Model.Recipes != null && Model.Recipes.Any())
        {
            @foreach (var recipe in Model.Recipes)
            {
                <div class="accordion-item shadow-sm mb-2">
                    <h2 class="accordion-header" id="heading-@recipe.Id">
                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapse-@recipe.Id">
                            <span class="fw-bold me-auto">@recipe.Name</span>
                            <span class="badge bg-secondary me-3">Oprettet af: Admin</span>
                        </button>
                    </h2>

                    <div id="collapse-@recipe.Id" class="accordion-collapse collapse" data-bs-parent="#recipeAccordion">
                        <div class="accordion-body">

                            <div class="row">

                                <div class="col-md-5 border-end">
                                    <h6>Ingredienser</h6>
                                    @if (recipe.Lines != null && recipe.Lines.Any())
                                    {
                                        <ul class="list-group list-group-flush mb-3">
                                            @foreach (var line in recipe.Lines)
                                            {
                                                <li class="list-group-item d-flex align-items-center px-0">
                                                    <input class="form-check-input me-3" type="checkbox" id="check-@line.Id">
                                                    <label class="form-check-label" for="check-@line.Id">
                                                        <strong>@line.Quantity.ToString("G")</strong> x @(line.Ware?.Name ?? "Ukendt vare")
                                                    </label>
                                                </li>
                                            }
                                        </ul>
                                    }
                                    else
                                    {
                                        <p class="text-muted small"><em>Ingen ingredienser.</em></p>
                                    }
                                </div>

                                <div class="col-md-7">
                                    <h6>Fremgangsmåde</h6>
                                    <p class="text-muted" style="white-space: pre-wrap;">@recipe.Description</p>
                                </div>

                            </div>

                            <hr />

                            <div class="d-flex justify-content-between align-items-center mt-3">
                                <small class="text-muted">
                                    <i class="bi bi-calendar3"></i> Oprettet: @DateTime.Now.ToString("dd. MMM yyyy")
                                </small>

                                <div class="btn-group">
                                    <button class="btn btn-outline-success btn-sm">Gem</button>
                                    <button class="btn btn-outline-secondary btn-sm">Gem som kladde</button>
                                    <button class="btn btn-outline-danger btn-sm">Slet</button>
                                </div>
                            </div>

                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="alert alert-info">
                Du har ikke oprettet nogle opskrifter endnu. Klik på "Ny opskrift" for at komme i gang!
            </div>
        }
    </div>
</div>
@page
@model Despenza.Pages.Inventory.GoodsReceiptModel
<div class=" RecipeTitleBox recipe-list-title">
    <h1>Varemodtagelse</h1>
</div>

@if (!string.IsNullOrEmpty(Model.SuccessMessage))
{
    <div class="alert alert-success mt-3" role="alert">
        @Model.SuccessMessage
    </div>
}

@if (!ViewData.ModelState.IsValid)
{
    <div class="alert alert-danger mt-3" role="alert">
        <div asp-validation-summary="All"></div>
    </div>
}

<form method="post" class="CoolForm">

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert alert-danger">
            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
            {
                <div>@error.ErrorMessage</div>
            }
        </div>
    }

    <div class="form-row">
        <label asp-for="IngredientId">Ingrediens</label>
        <select asp-for="IngredientId" asp-items="Model.IngredientOptions"></select>
    </div>

    <div class="form-row">
        <label asp-for="Amount">Mængde modtaget</label>
        <input asp-for="Amount" type="number" step="0.01" min="0" />
    </div>

    <div class="form-row">
        <label asp-for="UnitType">Enhed</label>
        <select asp-for="UnitType">
            <option value="gram">Gram</option>
            <option value="kg">Kilo</option>
        </select>
    </div>

    <button type="submit" class="CoolButton">Registrer varemodtagelse</button>
</form>
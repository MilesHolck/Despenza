@page
@using DespenzaLib.Migrations
@using DespenzaLib.Models
@model Despenza.Pages.Inventory.InventoryIndexModel
@inject DespenzaLib.Services.ProductionService ProdService

<h1 class=" RecipeTitleBox recipe-list-title">Lageroversigt</h1>
<br>
<h2 class=" RecipeTitleBox recipe-list-title">Ingredienser</h2>
<Div class="CoolTable">
    <table class="table mb-0">
        <thead>
            <tr>
                <th>Navn</th>
                <th>Kilopris</th>
                <th>Mængde</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.InventoryItems.Where(i => i.Ware is DespenzaLib.Models.Ingredient))
            {
                <tr>
                    <td>@item.Ware.Name</td>
                    <td>@item.Ware.KiloPrice.ToString("F2")</td>
                    <td>@item.QuantityInStock.ToString("F2") gram</td>
                </tr>
            }
        </tbody>
    </table>
</Div>

<h2 class=" RecipeTitleBox recipe-list-title">Halvfabrikater</h2>
<Div class="CoolTable">
    <table class="table mb-0">
        <thead>
            <tr>
                <th>Navn</th>
                <th>Kilopris</th>
                <th>Mængde</th>
                <th>Handling</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var semiProduct in Model.SemiProducts)
            {
                // Finder lagerværdien for dette specifikke halvfabrikat
                var stock = Model.InventoryItems.FirstOrDefault(i => i.WareId == semiProduct.Id)?.QuantityInStock ?? 0;

                <tr>
                    <td>@semiProduct.Name</td>
                    <td>@ProdService.CalculateRawMaterialCost(semiProduct.Recipe).ToString("C2")</td>
                    <td>@stock.ToString("F2") gram</td>
                    <td>
                        <form method="post" asp-page-handler="DeleteSemiProduct" asp-route-id="@semiProduct.Id">
                            <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Er du sikker på, at du vil slette dette halvfabrikat?');">
                                Slet
                            </button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</Div>

<h2 class=" RecipeTitleBox recipe-list-title">Helfabrikater</h2>
<Div class="CoolTable">
    <table class="table mb-0">
        <thead>
            <tr>
                <th>Navn</th>
                <th>Salgspris</th>
                <th>Mængde</th>
                <th>Handling</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var product in Model.Products)
            {
                var stock = Model.InventoryItems.FirstOrDefault(i => i.WareId == product.Id)?.QuantityInStock ?? 0;

                <tr>
                    <td>@product.Name</td>
                    <td>@ProdService.CalculateSalesPrice(product.Recipe).ToString("C2")</td>
                    <td>@stock.ToString("F2") gram</td>
                    <td>
                        <form method="post" asp-page-handler="DeleteProduct" asp-route-id="@product.Id">
                            <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Er du sikker på, at du vil slette dette helfabrikat?');">
                                Slet
                            </button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</Div>
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Despenza</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Despenza.styles.css" asp-append-version="true" />
</head>
<body class="d-flex flex-column min-vh-100">
    <header class="despenza-header">
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm despenza-navbar">
            <div class="container">
                <a class="navbar-brand" asp-area="" asp-page="/Index">Despenza</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <ul class="navbar-nav flex-grow-1">
                    @if (User.Identity != null && User.Identity.IsAuthenticated) 
                    {
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle text-dark"
                                   href="#"
                                   id="navbarDropdown"
                                   role="button"
                                   data-bs-toggle="dropdown"
                                   aria-expanded="false">
                                Lager
                            </a>
                                @if (User.IsInRole("Admin"))
                                {
                                    <ul class="dropdown-menu" aria-labelledby="navbarDropdown">
                                        <li><a class="dropdown-item" asp-page="/Admin/CreateIngredient">Opret ingrediens</a></li>
                                        <li><a class="dropdown-item" asp-page="/Admin/AllIngredients">Alle ingredienser</a></li>
                                        <li><hr class="dropdown-divider" /></li>
                                        <li><a class="dropdown-item" asp-page="/Inventory/GoodsReceipt">Registrer varemodtagelse</a></li>
                                        <li><hr class="dropdown-divider" /></li>
                                        <li><a class="dropdown-item" asp-page="/Inventory/RegisterWaste">Registrer spild</a></li>
                                        <li><a class="dropdown-item" asp-page="/Inventory/WasteOverview">Spildliste</a></li>
                                    </ul>
                                }
                                else
                                {
                                <ul class="dropdown-menu" aria-labelledby="navbarDropdown">                                    
                                    <li><a class="dropdown-item" asp-page="/Admin/AllIngredients">Alle ingredienser</a></li>
                                    <li><hr class="dropdown-divider" /></li>
                                    <li><a class="dropdown-item" asp-page="/Inventory/GoodsReceipt">Registrer varemodtagelse</a></li>
                                    <li><hr class="dropdown-divider" /></li>                                    
                                    <li><a class="dropdown-item" asp-page="/Inventory/WasteOverview">Spildliste</a></li>
                                </ul>
                                }
                            </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle text-light"
                                   href="#"
                                   id="navbarDropdown"
                                   role="button"
                                   data-bs-toggle="dropdown"
                                   aria-expanded="false">
                                Opskrifter
                            </a>
                            <ul class="dropdown-menu" aria-labelledby="navbarDropdown">
                                <li><a class="dropdown-item" asp-page="/RecipeSites/CreateRecipe">Opret ny opskrift</a></li>
                                <li><a class="dropdown-item" asp-page="/RecipeSites/RecipeList">Alle opskrifter</a></li>
                                <li><hr class="dropdown-divider" /></li>
                                <li><a class="dropdown-item" asp-page="/RecipeSites/RecipeDraft">Kladder</a></li>
                                <li><a class="dropdown-item" asp-page="/RecipeSites/DoneRecipe">Færdige opskrifter</a></li>
                            </ul>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle text-dark"
                                   href="#"
                                   id="navbarDropdown"
                                   role="button"
                                   data-bs-toggle="dropdown"
                                   aria-expanded="false">
                                Produkter
                            </a>
                            <ul class="dropdown-menu" aria-labelledby="navbarDropdown">
                                <li><a class="dropdown-item" asp-page="/Inventory/InventoryIndex">Se hele varelageret</a></li>
                            </ul>
                        </li>
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle text-dark"
                                       href="#"
                                       id="navbarDropdown"
                                       role="button"
                                       data-bs-toggle="dropdown"
                                       aria-expanded="false">
                                    Adminitration
                                </a>
                                <ul class="dropdown-menu" aria-labelledby="navbarDropdown">
                                    <li class="nav-item">
                                        <a class="nav-link text-dark" asp-area="" asp-page="/Admin/UserList">Alle Brugere</a>
                                    </li>
                                    <li class="nav-item">
                                        <a class="nav-link text-dark" asp-area="" asp-page="/Admin/CreateUser">Opret Bruger</a>
                                    </li>
                                </ul>
                            </li>
                    }
                    else {
                        
                    }
                    
                    
                    }
                </ul>
                <ul class="nav-item">
                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        <span>Logget ind som: @User.Identity.Name</span>
                        <form method="post" asp-page="/Authentication/Logout" style="display:inline;">
                            <button type="submit" class="btn btn-link LogOutButton">Log ud</button>
                        </form>
                    }
                    else
                    {
                        <a asp-page="/Authentication/LogIn" class="LoginButton">Log ind</a>
                    }
                </ul>
            </div>
        </nav>
    </header>
    <div class="container flex-grow-1">
        <main role="main" class="pb-5 mb-5">
            @RenderBody()
        </main>
    </div>
    
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>


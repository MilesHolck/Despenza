@page
@model Despenza.Pages.Authentication.LogInModel
@{

    ViewData["Title"] = "LogIn page";
}
<div class="CoolLoginBox"> 
    <h1>Log ind</h1>
    <form method="post">
        <div class="form-group">
            <label asp-for="Email">Email address</label>
            <input asp-for="Email" class="form-control" type="email" placeholder="Enter email">
        
        </div>
        <div class="form-group">
            <label asp-for="Password">Password</label>
            <input asp-for="Password" class="form-control" type="password" placeholder="Password">
        </div>
    
        <button type="submit" class="btn btn-primary">Submit</button>
    </form>

    @if (!string.IsNullOrEmpty(Model.Message))
    {
        <div class="alert alert-danger" role="alert">
            @Model.Message
        </div>
    }
</div>
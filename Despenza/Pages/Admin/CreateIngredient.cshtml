@page
@model Despenza.Pages.Admin.CreateIngredientModel

<div class="RecipeTitleBox recipe-list-title">
    <h1>Opret ingrediens</h1>
</div>

<div class="CoolForm">
    <form method="post">
        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger">
                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <div>@error.ErrorMessage</div>
                }
            </div>
        }
        <div>
            <label asp-for="Ingredient.Name">Navn</label>
            <input asp-for="Ingredient.Name" />
        </div>

        <div>
            <label asp-for="Ingredient.KiloPrice">Kilopris</label>
            <input asp-for="Ingredient.KiloPrice" />
        </div>              

        <button type="submit" class="btn btn-success">Opret</button>

    </form>
</div>
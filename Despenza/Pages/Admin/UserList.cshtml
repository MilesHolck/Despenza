@page
@model UserListModel
<h1>Medlemmer</h1>
<p>
    <a asp-page="CreateUser" class="btn btn-success mt-2">Opret ny bruger</a>
</p>
<div class=" CoolTable">
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Type</th>
                <th>Navn</th>
                <th>Handlinger</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model.Users)
            {
                <tr>
                    <td>
                        @user.GetType().Name
                    </td>
                    <td>@user.Name</td>
                    <td>
                        <a asp-page="./Edit"
                               asp-route-id="@user.Id"
                               class="btn btn-warning btn-sm me-1">
                            Edit
                        </a>


                        <form method="post" 
                            asp-page-handler="Delete">
                            <input type="hidden" asp-for"@user.Id" name="id" value="@user.Id" />

                            <button type="submit" 
                                class="btn btn-danger btn-sm"
                                onclick="return confirm('Er du sikker på, at du vil slette brugeren?');">
                            Delete
                            </button>
                        </form>

                    </td>
                 
                </tr>
            }
        </tbody>
    </table>
</div>


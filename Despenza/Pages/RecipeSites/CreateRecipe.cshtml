@page
@model CreateRecipeModel

<div class="container mt-4">
    <h3>Opret ny opskrift</h3>
    <form method="post" class="card p-4 shadow-sm">
        <div class="mb-3">
            <label asp-for="NewRecipe.Name" class="form-label">Navn på opskrift</label>
            <input asp-for="NewRecipe.Name" class="form-control" />
        </div>
        <div class="form-check mb-4">
            <input class="form-check-input" type="checkbox" asp-for="NewRecipe.IsSemiProduct" id="semiProductCheck" />
            <label class="form-check-label fw-bold text-primary" for="semiProductCheck">
                Halvfabrikat
            </label>
            <div class="form-check mb-4">
                <input class="form-check-input" type="checkbox" asp-for="NewRecipe.IsProduct" id="productCheck" />
                <label class="form-check-label fw-bold text-success" for="productCheck">
                    Helfabrikat
                </label>
            </div>
        </div>
        <div class="mb-3">
            @* <label asp-for="NewRecipe.QuantityOfProduct" class="form-label">opskriftensmængden i gram</label> *@
            @* <input asp-for="NewRecipe.QuantityOfProduct" type="number" class="form-control" min="1" /> *@
        </div>
        <div class="mb-3">
            <label asp-for="NewRecipe.Description" class="form-label">Beskrivelse</label>
            <textarea asp-for="NewRecipe.Description" class="form-control" rows="2"></textarea>
        </div>
        <h5>Ingredienser</h5>
        @for (int i = 0; i < Model.NewRecipe.Lines.Count; i++)
        {
            <div class="row g-2 mb-2">
                <div class="col-8">
                    <select asp-for="NewRecipe.Lines[i].WareId" asp-items="Model.WareOptions" class="form-select">
                        <option value="0">-- Vælg vare --</option>
                    </select>
                </div>
                <div class="col-4">
                    <input asp-for="NewRecipe.Lines[i].Quantity" class="form-control quantity-input" placeholder="Mængde" step="0.1" type="number" oninput="calculateTotalWeight()" />
                </div>
            </div>
        }
        <button type="submit" asp-page-handler="AddLine" class="btn btn-outline-secondary btn-sm" formnovalidate>+ Tilføj vare</button>
        <button type="submit" asp-page-handler="CalculateTotal" class="btn btn-info mt-2 text-white w-100">
            Beregn mængde
        </button>
        <div class="mt-3 fs-5">
            <strong>Samlet vægt: </strong> <span class="text-primary">@Model.NewRecipe.QuantityOfProduct</span> <strong>gram</strong>
        </div>
        <div class="form-group mb-3">
            <label class="fw-bold">Antal enheder: fx styks eller mængde ved grundopskrift</label>
            <input asp-for="NewRecipe.BaseYield" class="form-control" type="number" step="0.1" />
        </div>
        <hr />
        <button type="submit" asp-page-handler="Save" class="btn btn-success w-100">Gem Opskrift</button>
    </form>
</div>
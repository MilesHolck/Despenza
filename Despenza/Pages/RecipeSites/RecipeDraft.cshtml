@page
@model Despenza.Pages.RecipeSites.RecipeDraftModel
@{
    ViewData["Title"] = "Kladder";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Mine Kladder</h2>
    </div>
    @if (Model.Recipes != null && Model.Recipes.Any())
    {
        @foreach (var recipe in Model.Recipes)
        {
            <div class="accordion mb-3" id="draftAccordion-@recipe.Id">
                <div class="accordion-item shadow-sm border rounded overflow-hidden">
                    <h2 class="accordion-header position-relative" id="heading-@recipe.Id">
                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapse-@recipe.Id">
                            <span class="fw-bold me-auto">
                                <span class="ms-2 text-muted fw-normal" style="font-size: 0.85em;">
                                    - Kladde af: @(recipe.User != null ? recipe.User.Name : "Ukendt") (@recipe.DateSaved.ToString("dd. MMM"))
                                </span>
                            </span>
                        </button>

                        <div class="position-absolute top-50 end-0 translate-middle-y me-5 pe-3" style="z-index: 4;">
                            <form method="post" asp-page-handler="Delete" asp-route-id="@recipe.Id" class="d-inline">
                                <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Er du sikker på, at du vil slette denne kladde?');">Slet Kladde</button>
                            </form>
                        </div>
                    </h2>

                    <div id="collapse-@recipe.Id" class="accordion-collapse collapse" data-bs-parent="#draftAccordion-@recipe.Id">
                        <div class="accordion-body">

                         
                            <form method="post" asp-page-handler="CompleteDraft" asp-route-id="@recipe.Id">
                                <input type="hidden" name="scale" value="@recipe.RecipeScale" />

                                <div class="row">
                                    <div class="col-md-5 border-end">
                                        <h6>Ingredienser</h6>
                                        @if (recipe.Lines != null && recipe.Lines.Any())
                                        {
                                            <ul class="list-group list-group-flush mb-3">
                                                @foreach (var line in recipe.Lines)
                                                {
                                                    <li class="list-group-item d-flex align-items-center px-0">
                                                        @(line.IsChecked ? "" : "") 
                                                        <input class="form-check-input me-3" type="checkbox" name="checkedLines" id="check-@line.Id" value="@line.Id" @(line.IsChecked ? "" : "")>
                                                        <label class="form-check-label" for="check-@line.Id">
                                                            <strong>@line.Quantity.ToString("0.##")</strong> x @(line.Ware?.Name ?? "Ukendt vare")
                                                        </label>
                                                    </li>
                                                }
                                            </ul>
                                        }
                                        else
                                        {
                                            <p class="text-muted small"><em>Ingen ingredienser.</em></p>
                                        }
                                    </div>
                                    <div class="col-md-7">
                                        <h6>Fremgangsmåde</h6>
                                        <p class="text-muted" style="white-space: pre-wrap;">@recipe.Description</p>
                                    </div>
                                </div>
                                <div class="d-flex justify-content-end gap-2 mt-3"> 
                                    <button type="submit" asp-page-handler="CompleteDraft" asp-route-id="@recipe.Id" class="btn btn-success">
                                        Færdiggør Opskrift
                                    </button>

                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="alert alert-info" role="alert">
            Du har ingen gemte kladder lige nu.
        </div>
    }
</div>
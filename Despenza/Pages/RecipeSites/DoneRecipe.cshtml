@page
@model Despenza.Pages.RecipeSites.DoneRecipeModel
@{
    ViewData["Title"] = "Færdige Opskrifter";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="RecipeTitleBox">Færdige Opskrifter</h2>
    </div>
    <div class="accordion RecipeAccordion" id="doneRecipeAccordion">
        @if (Model.DoneRecipes != null && Model.DoneRecipes.Any())
        {
            foreach (var recipe in Model.DoneRecipes)
            {
                //
                <div class="accordion-item shadow-sm mb-2">
                    <h2 class="accordion-header position-relative" id="heading-@recipe.Id">
                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapse-@recipe.Id">
                            <span class="fw-bold me-auto">
                                @recipe.Name
                                <span class="ms-2 text-muted fw-normal" style="font-size: 0.85em;">
                                    - Lavet af: @(recipe.User != null ? recipe.User.Name : "Ukendt")
                                </span>
                            </span>
                        </button>
                        <div class="position-absolute top-50 end-0 translate-middle-y me-5 pe-3" style="z-index: 4;">
                            <a asp-page="/RecipeSites/RecipeEdit" asp-route-id="@recipe.Id" class="btn btn-warning btn-sm me-1">Ret</a>
                            <form method="post" asp-page-handler="Delete" asp-route-id="@recipe.Id" class="d-inline">
                                <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Er du sikker på, at du vil slette opskriften?');">Slet</button>
                            </form>
                        </div>
                    </h2>
                    <div id="collapse-@recipe.Id" class="accordion-collapse collapse" data-bs-parent="#doneRecipeAccordion">
                        <div class="accordion-body">
                            <div class="row">
                                <div class="col-md-5 border-end">
                                    <h6>Ingredienser</h6>
                                    @if (recipe.Lines != null && recipe.Lines.Any())
                                    {
                                        <ul class="list-group list-group-flush mb-3">
                                            @foreach (var line in recipe.Lines)
                                            {
                                                <li class="list-group-item d-flex align-items-center px-0">
                                                    @* <input class="form-check-input me-3" type="checkbox" id="check-@line.Id"> *@
                                                    <label class="form-check-label" for="check-@line.Id">
                                                        <strong>@line.Quantity.ToString("0.##")</strong> x @(line.Ware?.Name ?? "Ukendt vare")
                                                    </label>
                                                </li>
                                            }
                                        </ul>
                                    }
                                    else
                                    {
                                        <p class="text-muted small"><em>Ingen ingredienser.</em></p>
                                    }
                                </div>
                                <div class="col-md-7">
                                    <h6>Fremgangsmåde</h6>
                                    <p class="text-muted" style="white-space: pre-wrap;">@recipe.Description</p>
                                </div>
                            </div>
                            <hr />
                            <div class="d-flex justify-content-between align-items-center mt-3">
                                <small class="text-muted">
                                    <i class="bi bi-calendar3"></i> Gemt d.: @recipe.DateSaved.ToString("dd. MMM yyyy - kl. HH:mm")
                                </small>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="alert alert-info">Du har ikke gemt nogle færdige opskrifter endnu.</div>
        }
    </div>
</div>
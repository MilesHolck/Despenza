@page
@using DespenzaLib.Models
@model Despenza.Pages.RecipeListModel
@inject DespenzaLib.Services.ProductionService ProdService



<div class="container mt-4">

    <div class="recipe-list-page">

        <h2 class="RecipeTitleBox recipe-list-title">Mine Opskrifter</h2>

        <div class="recipe-action-panel">

            <a class="CoolButton recipe-action-button"
                   asp-page="/RecipeSites/CreateRecipe">
                Opret ny opskrift
            </a>

            <form method="get" class="recipe-search-form">

                <input type="text"
                       name="SearchText"
                       placeholder="Søg efter opskrift..."
                       value="@Model.SearchText"
                       class="recipe-search-input" />

                <select name="ExcludedAllergen" class="recipe-allergen-select">
                    <option value="">-- ingen --</option>

                    @foreach (var allergen in Enum.GetValues<Allergen>())
                    {
                        <option value="@allergen">
                            @allergen
                        </option>
                    }
                </select>

                <button type="submit" class="CoolButton">Søg</button>

            </form>

        </div>

        <div class="accordion RecipeAccordion" id="recipeAccordion">
            <!-- resten af din accordion-kode bliver her -->
        </div>

    </div>


    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="RecipeTitleBox">Mine Opskrifter</h2>
        @* <a asp-page="/Recipe/CreateRecipe" class="btn btn-primary">Ny opskrift</a> *@
        <a class="btn btn-dark mt-3"
           asp-page="/RecipeSites/CreateRecipe">
            Create a new Ingredient
        </a>
        <form method="get" class="CoolForm">
            <div class="form-row">
                <input type="text" name="SearchText" placeholder="Søg efter opskrift..." value="@Model.SearchText" />
            </div>

            <div class="form-row mt-2">
                <label>Fravælg allergen</label>

                <select name="ExcludedAllergen" class="form-select">
                    <option value="">-- ingen --</option>

                    @foreach (var allergen in Enum.GetValues<Allergen>())
                    {
                        <option value="@allergen">
                            @allergen
                        </option>
                    }

                </select>
            </div>
            <button type="submit" class="CoolButton">Søg</button>
        </form>
    </div>
    <div class="accordion RecipeAccordion" id="recipeAccordion">
        @* <div asp-validation-summary="All" class="alert alert-danger fw-bold mb-2"></div> *@

        @if (Model.Recipes != null && Model.Recipes.Any())
        {
            @foreach (var recipe in Model.Recipes)
            {

                <div class="accordion-item mb-2 position-relative">
                    <h2 class="accordion-header position-relative" id="heading-@recipe.Id">
                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapse-@recipe.Id">
                            <span class="fw-bold">@recipe.Name</span>
                            <span class="position-absolute start-50 translate-middle-x">pris: @ProdService.CalculateRawMaterialCost(recipe).ToString("C2")</span>
                        </button>
                        <div class="position-absolute top-50 end-0 translate-middle-y d-flex align-items-center pe-5" style="z-index: 4;">
                            <a asp-page="/RecipeSites/RecipeEdit" asp-route-id="@recipe.Id" class="btn btn-warning btn-sm me-2">Ret</a>
                            <form method="post" asp-page-handler="Delete" asp-route-id="@recipe.Id" class="m-0 p-0 d-inline">
                                <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Er du sikker på, at du vil slette opskriften?');">Slet</button>
                            </form>
                        </div>
                    </h2>
                    <div id="collapse-@recipe.Id" class="accordion-collapse collapse @(ViewData["ActiveRecipeId"]?.ToString() == recipe.Id.ToString() ? "show" : "")" data-bs-parent="#recipeAccordion">
                        <div class="accordion-body">
                            <form method="get" class="d-flex align-items-center mb-3 bg-light p-2 rounded">
                                <input type="hidden" name="scaleRecipeId" value="@recipe.Id" />
                                <label class="me-2 small fw-bold mb-0">Skaler opskrift:</label>
                                <select name="scale" class="form-select form-select-sm me-2" style="width: auto;">
                                    <option value="0.5" selected="@(recipe.RecipeScale == 0.5m)">0,5x</option>
                                    <option value="1" selected="@(recipe.RecipeScale == 1.0m)">1x (Standard)</option>
                                    <option value="1.5" selected="@(recipe.RecipeScale == 1.5m)">1,5x</option>
                                    <option value="2" selected="@(recipe.RecipeScale == 2.0m)">2x</option>
                                    <option value="3" selected="@(recipe.RecipeScale == 3.0m)">3x</option>
                                </select>
                                <button type="submit" class="btn btn-outline-primary btn-sm">Opdater tal</button>
                            </form>
                            <form method="post">
                                <input type="hidden" name="scale" value="@recipe.RecipeScale" />
                                <div class="row">
                                    <div class="col-md-5 border-end">
                                        <h6>Ingredienser</h6>
                                        @if (recipe.Lines != null && recipe.Lines.Any())
                                        {
                                            <ul class="list-group list-group-flush mb-3">
                                                @foreach (var line in recipe.Lines)
                                                {
                                                    <li class="list-group-item d-flex align-items-center px-0">
                                                        @{
                                                            decimal currentStock = Model.LineStockAmount.ContainsKey(line.Id) ? Model.LineStockAmount[line.Id] : 0m;
                                                            bool hasStock = currentStock >= line.Quantity;
                                                        }
                                                        <input class="form-check-input me-3" type="checkbox" name="checkedLines" id="check-@line.Id" value="@line.Id" @(line.IsChecked ? "checked" : "")>
                                                        <label class="form-check-label @(hasStock ? "" : "text-danger fw-bold")" for="check-@line.Id">
                                                            <strong>@line.Quantity.ToString("0.##")</strong> x @(line.Ware?.Name ?? "Ukendt vare")
                                                            @if (!hasStock)
                                                            {
                                                                <span class="badge bg-danger ms-2">
                                                                    @currentStock.ToString("0.##") på lager
                                                                </span>
                                                            }
                                                        </label>

                                                    </li>
                                                }
                                            </ul>
                                        }
                                        else
                                        {
                                            <p class="text-muted small"><em>Ingen ingredienser.</em></p>
                                        }
                                    </div>

                                </div>
                                <div class="col-md-7">
                                    @if (Model.StockErrorRecipeId == recipe.Id && !string.IsNullOrWhiteSpace(Model.StockErrorMessage))
                                    {
                                        <div class="alert alert-danger fw-bold">
                                            @Model.StockErrorMessage
                                        </div>
                                    }

                                    <h6>Fremgangsmåde</h6>
                                    <p class="text-muted" style="white-space: pre-wrap;">@recipe.Description</p>
                                </div>
                                <div class="mt-4 p-3 bg-light border rounded">
                                    <h6 class="text-muted mb-2">Opskriftens udbytte</h6>
                                    <div class="d-flex justify-content-between mb-1">
                                        <span>Samlet mængde:</span>
                                        <strong>@((recipe.QuantityOfProduct * recipe.RecipeScale).ToString("0.##")) g</strong>
                                    </div>
                                    <div class="d-flex justify-content-between">
                                        <span>Forventet antal:</span>
                                        <span class="badge bg-success fs-6">@((recipe.BaseYield * recipe.RecipeScale).ToString("0.##")) stk</span>
                                    </div>
                                </div>
                                <hr />
                                <div class="d-flex justify-content-between align-items-center">
                                    <small class="text-muted">
                                        <i class="bi bi-calendar3"></i> Oprettet: @DateTime.Now.ToString("dd. MMM yyyy")
                                    </small>
                                    <div class="d-flex justify-content-between text-secondary">
                                        <span>Råvarepris (Fremstillingspris):</span>
                                        <span>@ProdService.CalculateRawMaterialCost(recipe).ToString("C2")</span>
                                    </div>

                                    @if (recipe.IsProduct)
                                    {
                                        <div class="d-flex justify-content-between fw-bold text-success mt-1 border-top pt-1">
                                            <span>Vejledende Salgspris (inkl. moms):</span>
                                            <span>@ProdService.CalculateSalesPrice(recipe).ToString("C2")</span>
                                        </div>
                                    }
                                </div>
                                <div class="btn-group">
                                    <div class="d-flex justify-content-end gap-2 mt-3">

                                        <button type="submit" asp-page-handler="SaveCopy" asp-route-id="@recipe.Id" class="btn btn-success btn-sm">
                                            Færdiggør opskrift
                                        </button>

                                        <button type="submit" asp-page-handler="SaveDraft" asp-route-id="@recipe.Id" class="btn btn-warning btn-sm">
                                            Gem som kladde
                                        </button>
                                    </div>
                                </div>
                            </form>
                        </div>
                        <hr />
                        <div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="alert alert-info">
                Du har ikke oprettet nogle opskrifter endnu. Klik på "Ny opskrift" for at komme i gang!
            </div>
        }
    </div>
</div>